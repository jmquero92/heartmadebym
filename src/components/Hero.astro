---
// Hero.astro
---

<div class="relative h-[100dvh] w-full overflow-hidden bg-gray-900">
  
  {/* 1. IMAGEN DE FONDO */}
  <div class="absolute inset-0 w-full h-full animate-zoom-in">
    <img 
      src="/portada.webp" 
      alt="Hero Background" 
      fetchpriority="high" 
      decoding="sync" 
      class="absolute inset-0 w-full h-full object-cover transform-gpu" 
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-transparent to-white/10 opacity-60 mix-blend-overlay pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/80"></div>
  </div>

  {/* 2. CONTENIDO */}
  <div class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center pb-16 md:pb-0">
    
    {/* Tagline Superior */}
    <div class="mb-4 flex flex-col items-center gap-2 -mt-32 md:-mt-64 animate-fade-in-tagline">
      <span class="text-[10px] font-medium uppercase tracking-[0.4em] text-white/90 font-sans [text-shadow:0_2px_4px_rgba(0,0,0,0.5)]">
        Handcrafted in Spain
      </span>
      <span class="h-[1px] w-6 bg-rose-200/80 shadow-md"></span>
    </div>

    {/* Título Principal */}
    <h1 class="relative -mt-4 md:-mt-8 font-serif text-6xl font-normal text-white md:text-8xl lg:text-9xl tracking-tight leading-[1.1] [text-shadow:0_8px_16px_rgba(0,0,0,0.5)] animate-slide-up-title">
      <span class="italic text-white">Heartmade</span>
      <span class="block text-4xl md:text-6xl not-italic text-rose-100 font-light mt-[-0.2em] md:mt-[-0.3em] [text-shadow:0_4px_8px_rgba(0,0,0,0.5)]">
        by M
      </span>
    </h1>

    {/* Subtítulo: Máquina de Escribir */}
    <div class="mt-8 max-w-lg min-h-[3.5rem] flex items-start justify-center animate-fade-in-subtitle">
      <p class="text-base font-medium leading-7 text-white/90 font-sans md:text-lg tracking-wide [text-shadow:0_2px_4px_rgba(0,0,0,0.5)]">
        <span id="typewriter-text"></span>
        <span class="animate-pulse font-light text-rose-200 ml-1">|</span>
      </p>
    </div>

  </div>
</div>

<script>
  const phrases = [
    "Hecho a mano desde el corazón.",
    "Cada puntada cuenta una historia.",
    "El lujo de lo creado sin prisas.",
    "Piezas únicas con alma propia."
  ];

  const typeWriterEl = document.getElementById('typewriter-text');
  
  if (typeWriterEl) {
    let loopNum = 0;
    let isDeleting = false;
    let text = "";
    let typingSpeed = 50;

    function type() {
      const i = loopNum % phrases.length;
      const fullText = phrases[i];

      if (isDeleting) {
        text = fullText.substring(0, text.length - 1);
        typingSpeed = 20;
      } else {
        text = fullText.substring(0, text.length + 1);
        typingSpeed = 50;
      }

      typeWriterEl.textContent = text;

      let nextTick = typingSpeed;

      if (!isDeleting && text === fullText) {
        nextTick = 1500; // pausa al final
        isDeleting = true;
      } else if (isDeleting && text === "") {
        isDeleting = false;
        loopNum++;
        nextTick = 500; // pausa antes de la siguiente frase
      }

      setTimeout(type, nextTick);
    }

    // Iniciar con un pequeño retraso
    setTimeout(type, 800);
  }
</script>

<style>
@keyframes zoomIn {
  from { transform: scale(1.1); }
  to { transform: scale(1); }
}
.animate-zoom-in {
  animation: zoomIn 10s ease-out forwards;
}

@keyframes fadeInTagline {
  from { opacity: 0; letter-spacing: 0.2em; }
  to { opacity: 1; letter-spacing: 0.4em; }
}
.animate-fade-in-tagline {
  animation: fadeInTagline 1.2s ease-out 0.2s forwards;
  opacity: 0;
}

@keyframes slideUpTitle {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-slide-up-title {
  animation: slideUpTitle 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  opacity: 0;
}

@keyframes fadeInSubtitle {
  from { opacity: 0; }
  to { opacity: 1; }
}
.animate-fade-in-subtitle {
  animation: fadeInSubtitle 1s ease-out 0.8s forwards;
  opacity: 0;
}
</style>

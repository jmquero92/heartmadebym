---
// ContactSection.astro
---

<section 
  id="contacto" 
  class="relative w-full px-4 py-12 md:py-32 rounded-t-[2rem] md:rounded-t-[3rem] shadow-[0_-10px_40px_rgba(0,0,0,0.1)] z-40 mt-[-2rem] overflow-hidden min-h-[90dvh] flex items-center justify-center bg-[#fafaf9]"
>
  
  {/* --- CONTENEDOR PRINCIPAL: LA "TARJETA PREMIUM" --- */}
  <div class="relative z-10 bg-white w-full max-w-6xl rounded-sm shadow-xl border border-[#2c2420]/5 overflow-hidden flex flex-col-reverse md:flex-row min-h-[600px] animate-fade-in-up">

    {/* 1. COLUMNA IZQUIERDA: FORMULARIO (60% ancho) */}
    <div class="w-full md:w-3/5 p-10 md:p-16 flex flex-col justify-center">
      
      <div class="max-w-md mx-auto w-full">
        <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-400 mb-6 flex items-center gap-2">
          <span class="w-6 h-[1px] bg-rose-300"></span>
          Atelier
        </span>

        <h2 class="font-serif text-3xl md:text-5xl text-[#2c2420] italic mb-4 leading-tight">
          Hablemos
        </h2>
        <p class="text-sm text-neutral-500 font-light font-sans mb-10 leading-relaxed">
          Cada pieza comienza con una idea. Escríbeme para encargos personalizados o dudas sobre la colección.
        </p>

        {/* Mensaje de Éxito (Oculto por defecto) */}
        <div id="form-success" class="hidden py-10 text-center bg-[#fafaf9] border border-[#2c2420]/5 rounded-sm">
          <span class="text-2xl">✨</span>
          <h3 class="font-serif text-xl text-[#2c2420] italic mt-2">Mensaje enviado</h3>
          <p class="text-xs text-neutral-500 mt-1">Te responderé en breve.</p>
          <button id="btn-reset" class="mt-4 text-[10px] uppercase tracking-widest underline text-neutral-400 hover:text-[#2c2420]">
            Escribir otro
          </button>
        </div>

        {/* Formulario */}
        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="group">
              <input type="text" required placeholder="Nombre" class="w-full bg-transparent border-b border-neutral-200 py-2 text-sm text-[#2c2420] placeholder-neutral-400 focus:border-[#2c2420] focus:outline-none transition-colors"/>
            </div>
            <div class="group">
              <input type="email" required placeholder="Email" class="w-full bg-transparent border-b border-neutral-200 py-2 text-sm text-[#2c2420] placeholder-neutral-400 focus:border-[#2c2420] focus:outline-none transition-colors"/>
            </div>
          </div>
          <div class="group">
            <textarea rows="3" required placeholder="Tu mensaje..." class="w-full bg-transparent border-b border-neutral-200 py-2 text-sm text-[#2c2420] placeholder-neutral-400 focus:border-[#2c2420] focus:outline-none transition-colors resize-none"></textarea>
          </div>
          <button type="submit" id="btn-submit" class="pt-4 text-xs uppercase tracking-[0.25em] text-[#2c2420] font-bold hover:text-rose-500 transition-colors flex items-center gap-2">
            <span id="submit-text">Enviar ahora</span>
            <span class="text-lg leading-none">→</span>
          </button>
        </form>

        {/* Footer interno minimalista */}
        <div class="mt-12 pt-6 border-t border-neutral-100 flex gap-8 text-[10px] uppercase tracking-widest text-neutral-400">
           <div>hola@heartmadebym.com</div>
           <div>@heartmadebym</div>
        </div>
      </div>
    </div>

    {/* 2. COLUMNA DERECHA: EL MAPA EN COLOR (40% ancho) */}
    <div class="w-full md:w-2/5 relative min-h-[300px] md:min-h-full border-l border-[#2c2420]/5">
      
      <iframe 
         title="Mapa La Rambla"
         src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12621.685743625476!2d-4.7456743!3d37.6068249!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd6d22666d3288d3%3A0x40463fd8ca1c720!2s14540%20La%20Rambla%2C%20C%C3%B3rdoba!5e0!3m2!1ses!2ses!4v1709650000000!5m2!1ses!2ses"
         width="100%" 
         height="100%" 
         style="border: 0;" 
         allowfullscreen="" 
         loading="lazy" 
         referrerpolicy="no-referrer-when-downgrade"
         class="absolute inset-0 w-full h-full object-cover"
      ></iframe>

      {/* Etiqueta flotante "Premium" sobre el mapa */}
      <div class="absolute top-6 right-6 bg-white px-5 py-3 shadow-lg rounded-sm border-l-2 border-rose-300">
         <span class="block text-[10px] uppercase tracking-widest text-neutral-400 mb-1">Ubicación</span>
         <span class="block font-serif text-lg text-[#2c2420] italic leading-none">La Rambla</span>
         <span class="block text-[10px] text-neutral-500 mt-1">Córdoba, España</span>
      </div>

    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');
  const btnReset = document.getElementById('btn-reset');
  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text');

  if (form && successMsg && btnReset && btnSubmit && submitText) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      btnSubmit.disabled = true;
      submitText.textContent = "Enviando...";

      // Simular envío
      setTimeout(() => {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
        btnSubmit.disabled = false;
        submitText.textContent = "Enviar ahora";
      }, 1500);
    });

    btnReset.addEventListener('click', () => {
      form.reset();
      successMsg.classList.add('hidden');
      form.classList.remove('hidden');
    });
  }
</script>

<style>
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in-up {
  animation: fadeInUp 0.8s ease-out forwards;
}
</style>
